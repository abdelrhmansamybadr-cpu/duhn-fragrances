Options -Indexes
Options -MultiViews

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://fonts.gstatic.com https://cdn.jsdelivr.net; font-src 'self' https://fonts.gstatic.com https://cdn.jsdelivr.net; img-src 'self' data: https:; connect-src 'self'; frame-ancestors 'self'"
    Header always unset X-Powered-By
    Header always unset Server
</IfModule>

# Force HTTPS
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTPS} off
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# Rewrite rules
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Block access to sensitive files
    RewriteRule ^\.env$           - [F,L]
    RewriteRule ^\.git/           - [F,L]
    RewriteRule ^api/config/      - [F,L]
    RewriteRule ^api/migrations/  - [F,L]

    # Serve static files and existing directories as-is
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # API requests → api/index.php
    RewriteRule ^api/(.*)$ api/index.php [QSA,L]

    # Sitemap → sitemap.php
    RewriteRule ^sitemap\.xml$ sitemap.php [QSA,L]

    # Clean product URLs: /product/carnation → product.php?slug=carnation
    RewriteRule ^product/([a-z0-9-]+)/?$ product.php?slug=$1 [QSA,L]

    # Clean collection URLs: /collections/for-him → collections.php?slug=for-him
    RewriteRule ^collections/([a-z0-9-]+)/?$ collections.php?slug=$1 [QSA,L]

    # 404 handler
    ErrorDocument 404 /404.php
</IfModule>

# Compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json
</IfModule>

# Cache static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg  "access plus 30 days"
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/png  "access plus 30 days"
    ExpiresByType image/webp "access plus 30 days"
    ExpiresByType text/css   "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
</IfModule>

# Limit request size (5MB)
LimitRequestBody 5242880

# Disable PHP in uploads
<IfModule mod_php.c>
    <DirectoryMatch "api/uploads/">
        php_flag engine off
    </DirectoryMatch>
</IfModule>
